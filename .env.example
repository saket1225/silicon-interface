# Copy to .env.local. Pointed at the local Django dev server by default.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
NEXT_PUBLIC_WS_BASE=ws://127.0.0.1:8000

# PostHog (analytics + session replay). Project token from
# https://us.posthog.com → Project Settings. Without it, PostHog is a no-op.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
